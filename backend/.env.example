DOMAIN=shopping.example.com

# The admin superuser is created the first time you open /admin (setup wizard).
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER_NAME=ShoppingList
SMTP_SENDER_ADDRESS=noreply@example.com

# Optional Bring connector service account and Bring credentials
PB_SERVICE_EMAIL=
PB_SERVICE_PASSWORD=
BRING_EMAIL=
BRING_PASSWORD=
SYNC_INTERVAL_MS=60000
