DOMAIN=shopping.example.com

# Instance admin (separate from app users). Set ADMIN_PASSWORD to configure the
# admin panel from here: the admin is created/updated on every boot, so editing
# this value + restarting resets or rotates the password, and the panel shows a
# password-only login. Must be at least 8 characters. ADMIN_EMAIL is the admin
# identity (default admin@haul.local). Leave ADMIN_PASSWORD empty to instead
# create the admin via the first-run setup wizard at /admin.
ADMIN_EMAIL=admin@haul.local
ADMIN_PASSWORD=

# Instance config. Any value set here PREVAILS over the admin panel (re-seeded on
# every boot) and locks that field (read-only) in the panel. Leave empty to let
# the admin manage it. Booleans: true/false.
#   SERVER_NAME        display name of the instance
#   ENABLE_WEB_APP     false => the web shows "mobile only" (API/admin still work)
#   ENABLE_USERNAMES   show who's connected to a list (beta)
#   REQUIRE_ACCOUNT    true => no guest use; the app requires login/registration
#   REGISTRATION_OPEN  false => no new accounts (login only); admin can still create them
SERVER_NAME=
ENABLE_WEB_APP=
ENABLE_USERNAMES=
REQUIRE_ACCOUNT=
REGISTRATION_OPEN=

SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER_NAME=ShoppingList
SMTP_SENDER_ADDRESS=noreply@example.com

# Optional Bring connector service account and Bring credentials
PB_SERVICE_EMAIL=
PB_SERVICE_PASSWORD=
BRING_EMAIL=
BRING_PASSWORD=
SYNC_INTERVAL_MS=60000
